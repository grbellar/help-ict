  "trees": {
    "person_in_need": {
      "root": "Q0a_for_whom",
      "nodes": {
        "Q0a_for_whom": {
          "type": "question",
          "prompt": "Who are you asking for?",
          "options": [
            { "label": "For me", "next": "Q1_age" },
            {
              "label": "For someone else",
              "redirect_tree": "worried_about_someone"
            }
          ],
          "llm_fallback": false
        },

        "Q1_age": {
          "type": "question",
          "prompt": "How old are you?",
          "options": [
            { "label": "Under 18", "next": "Q2_under18_safe" },
            { "label": "18-24", "next": "Q2_youth_foster" },
            { "label": "25+", "next": "Q2_adult_kids" }
          ],
          "llm_fallback": false
        },

        "Q2_under18_safe": {
          "type": "question",
          "prompt": "Are you safe right now?",
          "options": [
            {
              "label": "No",
              "leaf": "safe_place_line",
              "also_dispatch": "crossroads_street"
            },
            { "label": "Yes", "leaf": "crossroads_dropin" }
          ]
        },

        "Q2_youth_foster": {
          "type": "question",
          "prompt": "Were you in foster care at age 14 or older?",
          "options": [
            {
              "label": "Yes",
              "set_flag": { "foster_history": true },
              "next": "Q3_youth_need"
            },
            { "label": "No", "next": "Q3_youth_need" },
            { "label": "Not sure", "next": "Q3_youth_need" }
          ]
        },

        "Q3_youth_need": {
          "type": "question",
          "prompt": "What do you need most right now?",
          "options": [
            {
              "label": "Bed tonight",
              "set_flag": { "needs_bed_tonight": true },
              "next": "Q4_youth_vulnerability"
            },
            { "label": "Housing (not shelter)", "next": "Q4_youth_housing" },
            {
              "label": "Help planning / case mgmt",
              "leaf": "crossroads_dropin"
            }
          ]
        },

        "Q4_youth_vulnerability": {
          "type": "question",
          "prompt": "Any of these apply? (pick one)",
          "options": [
            {
              "label": "Pregnant or parenting",
              "leaf": "bridges",
              "priority": "high"
            },
            {
              "label": "Fleeing violence or trafficking",
              "set_flag": { "dv_flag": true }
            },
            {
              "label": "None of these",
              "leaf": "bridges",
              "fallback": "crossroads_dropin"
            }
          ]
        },

        "Q4_youth_housing": {
          "type": "question",
          "prompt": "Do you have income or a housing voucher?",
          "options": [
            {
              "label": "I have a voucher",
              "set_flag": { "has_voucher": true },
              "leaf": "nextenant"
            },
            { "label": "I have some income", "leaf": "rapid_rehousing_intake" },
            {
              "label": "Neither",
              "leaf": "bridges",
              "fallback": "second_light"
            }
          ]
        },

        "Q2_adult_kids": {
          "type": "question",
          "prompt": "Do you have children under 18 in your care right now?",
          "options": [
            {
              "label": "Yes",
              "set_flag": { "with_kids": true },
              "leaf": "family_handoff"
            },
            { "label": "No", "next": "Q3_adult_tonight" }
          ]
        },

        "Q3_adult_tonight": {
          "type": "question",
          "prompt": "Do you need a bed tonight?",
          "options": [
            {
              "label": "Yes",
              "set_flag": { "needs_bed_tonight": true },
              "next": "Q4_adult_timeofday"
            },
            { "label": "No", "next": "Q4_adult_situation" }
          ]
        },

        "Q4_adult_timeofday": {
          "type": "computed",
          "compute": "time_of_day",
          "branches": [
            {
              "when": "07:00-17:00_weekday",
              "leaf": "open_door",
              "fallback": "second_light"
            },
            {
              "when": "otherwise",
              "leaf": "second_light",
              "fallback": "center_of_hope"
            }
          ]
        },

        "Q4_adult_situation": {
          "type": "question",
          "prompt": "Which best describes you right now?",
          "options": [
            {
              "label": "On the street / in a car",
              "leaf": "open_door",
              "then_refer": "second_light"
            },
            {
              "label": "Couch surfing / doubled up",
              "leaf": "open_door",
              "then_refer": "rapid_rehousing_intake"
            },
            {
              "label": "I have a voucher, need a home",
              "set_flag": { "has_voucher": true },
              "leaf": "nextenant"
            },
            {
              "label": "Facing eviction",
              "leaf": "rapid_rehousing_intake",
              "priority": "prevention"
            }
          ]
        }
      }
    },

    "worried_about_someone": {
      "root": "QW1",
      "nodes": {
        "QW1": {
          "type": "question",
          "prompt": "Who is the person you're worried about?",
