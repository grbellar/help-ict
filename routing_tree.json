            }
          ]
        }
      }
    }
  },

  "llm_fallback_policy": {
    "when_invoked": [
      "user taps 'I don't see my situation'",
      "free-text input on an opt-in field",
      "multiple leaves qualify and a tradeoff explanation is requested"
    ],
    "constraints": [
      "MUST map input to an existing node ID or endpoint ID; MUST NOT invent endpoints",
      "MUST return structured JSON: { next_node | leaf, set_flags, confidence }",
      "IF confidence < 0.8 THEN escalate to human navigator with collected context",
      "MUST log every invocation with input, output, and rationale for offline audit"
    ]
  }
